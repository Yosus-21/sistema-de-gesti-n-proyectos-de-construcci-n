# App
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=suarq_db
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/suarq_db?schema=public"

# Security
# Use a random secret of at least 32 characters in production.
# Never commit real production secrets.
JWT_SECRET=change-me-in-production-use-32-plus-random-characters
JWT_EXPIRES_IN=1h
BCRYPT_SALT_ROUNDS=10

# Public registration is only for development/test bootstrap.
# In production the app fails to start if this is true.
AUTH_REGISTER_ENABLED=true

# Admin bootstrap
# Example values only. Use a strong, temporary password in production and never commit real secrets.
ADMIN_EMAIL=admin@suarq.local
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NOMBRE=Administrador
ADMIN_OVERWRITE_PASSWORD=false

# CORS
CORS_ENABLED=true
CORS_ORIGIN=http://localhost:3000
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE
CORS_CREDENTIALS=true

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Email notifications
EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM=no-reply@suarq.local

# Reports
REPORTS_DIR=reports

# AI / Google Gemini
AI_ENABLED=false
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash
GOOGLE_AI_TIMEOUT_MS=15000

